/* Basic Reset */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* Landing Page Styling with Background Image */
.landing-page {
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: url('/images/land.png') no-repeat center center fixed;
    background-size: cover;
    color: rgba(0, 0, 0, 0.7);
}

.landing-page::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.3); /* Matte black with 70% opacity */
    z-index: 1;
}


.profile-image {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    border: 4px solid rgba(0, 0, 0, 0.7);
    box-shadow: 0 0 15px rgba(0, 0, 0, 0.3);
}

.profile-name {
    font-size: 4.5rem;
    font-weight: bold;
    color: rgba(0, 0, 0, 0.7);
    z-index: 2;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.4);
    margin-top: 20px;
}

/* Initial styling for profile name */
.profile-name span {
    display: inline-block;
    opacity: 1;
    transition: transform 0.5s ease, opacity 0.5s ease;
}

/* Falling animation (when scrolling down) */
.profile-name.falling span {
    transform: translateY(100px);
    opacity: 0;
}

/* Rising animation (when scrolling up) */
.profile-name.rising span {
    transform: translateY(0);
    opacity: 1;
}

/* Staggered delay for each character */
.profile-name span:nth-child(1) { transition-delay: 0s; }
.profile-name span:nth-child(2) { transition-delay: 0.1s; }
.profile-name span:nth-child(3) { transition-delay: 0.2s; }
.profile-name span:nth-child(4) { transition-delay: 0.3s; }
.profile-name span:nth-child(5) { transition-delay: 0.4s; }
.profile-name span:nth-child(6) { transition-delay: 0.5s; }
.profile-name span:nth-child(7) { transition-delay: 0.6s; }
.profile-name span:nth-child(8) { transition-delay: 0.7s; }
.profile-name span:nth-child(9) { transition-delay: 0.8s; }
.profile-name span:nth-child(10) { transition-delay: 0.9s; }
/* Repeat for each character as needed */

.typing-effect {
    color: #d4a373;
    font-size: 1.5rem;
    font-weight: 400;
    margin-top: 10px;
    height: 2rem;
}

.scroll-down {
    font-size: 1rem;
    color: rgba(0, 0, 0, 0.7);
    opacity: 0.8;
    margin-top: 30px;
    cursor: pointer;
    transition: color 0.3s ease;
    animation: bounce 2s infinite;
}

.scroll-down:hover {
    color: #ffffff;
    opacity: 1;
}

/* Bounce Animation */
@keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
}

