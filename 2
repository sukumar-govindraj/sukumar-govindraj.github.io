/* Education --------------------------------------------*/

/* Education Section Styling */
#education {
    position: relative;
    width: 100vw;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
    background: url('../images/background.png') no-repeat center center fixed;
    background-size: cover;
    color: #333;
}


.education-background-text {
    position: absolute;
    font-size: 12vw;
    color: rgba(0, 0, 0, 0.1); /* Darker color for better visibility */
    font-weight: bold;
    z-index: 1;
    top: 5%;
    left: 50%;
    transform: translateX(-50%);
    text-transform: uppercase;
    letter-spacing: 1rem;
}
.education-content {
    z-index: 2;
    width: 80%;
    max-width: 800px;
}

.education-card {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.85); /* More opaque background */
    border-radius: 10px;
    box-shadow: 0px 4px 15px rgba(0, 0, 0, 0.25); /* Darker shadow for depth */
    padding: 20px;
    margin-bottom: 30px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.education-card:hover {
    transform: translateY(-5px);
    box-shadow: 0px 6px 20px rgba(0, 0, 0, 0.3); /* Stronger shadow on hover */
}

.institution-logo {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    margin-right: 20px;
    object-fit: cover;
    border: 3px solid #4A90E2; /* Darker border for visibility */
    box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.2); /* Shadow to elevate the logo */
}

.education-details h3 {
    font-size: 1.5rem;
    font-weight: bold;
    margin: 0;
    color: #333333; /* Darker font color for main title */
}

.education-details h4 {
    font-size: 1rem;
    font-weight: normal;
    color: #555555; /* Slightly darker font color for subheading */
    margin: 5px 0 15px;
}

.education-details p {
    font-size: 0.9rem;
    color: #666666; /* Darker font color for body text */
    line-height: 1.6;
}

/* Animation for section fade-in */
#education {
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
}

#education.visible {
    opacity: 1;
}

/* Work Experience */

#work-experience {
    position: relative;
    width: 100vw;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
    background: url('../images/work.jpg') no-repeat center center fixed;
    background-size: cover;
    color: #333;
    overflow: hidden;
}

/* Background Title Styling */
.work-background-title {
    position: absolute;
    top: 10%;
    left: 50%;
    transform: translateX(-50%);
    font-size: 5vw; /* Font size for background title */
    color: rgba(255, 255, 255, 0.45); /* Increased opacity for a darker effect */
    font-weight: bold;
    z-index: 1;
    text-transform: uppercase;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
}

/* Work Content Grid */
.work-content {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
    width: 90%;
    max-width: 1200px;
    z-index: 2;
}

/* Work Card */
.work-card {
    position: relative;
    width: 100%;
    background-color: #fff;
    border-radius: 15px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    padding: 20px;
    text-align: left;
    transition: box-shadow 0.3s ease;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.work-card:hover {
    box-shadow: 0px 12px 30px rgba(0, 0, 0, 0.2);
}

/* Card Header with Logo and Text */
.card-header {
    display: flex;
    align-items: center;
}

.circle {
    width: 60px;
    height: 60px;
    margin-right: 15px;
    background-color: #f0f0f0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.circle img {
    width: 100%;
    height: auto;
    object-fit: cover;
}

/* Text Content */
.text-content h3 {
    font-size: 1.2rem; /* Reduced font size for job title */
    font-weight: bold;
    color: #333;
    margin: 0;
}

.text-content .short-description {
    font-size: 0.9rem; /* Adjusted font size for organization name */
    color: #555;
}

.text-content .date-range {
    font-size: 0.8rem; /* Adjusted font size for date range */
    color: #777;
}

/* Read More Link Styling */
.read-more {
    color: #007BFF;
    cursor: pointer;
    text-decoration: underline;
    font-size: 0.9rem; /* Adjusted font size for Read More */
    text-align: center;
}

/* Modal styling for expanded content */
/* Modal styling for expanded content */
.expanded-content {
    position: fixed;
    top: 50%;
    left: 50%;
    width: 75vw;
    height: 75vh;
    max-width: 900px;
    max-height: 700px;
    padding: 30px;
    background-color: rgba(255, 255, 255, 0.98);
    border-radius: 15px;
    opacity: 0;
    visibility: hidden;
    transform: translate(-50%, -50%) scale(0.9);
    transition: opacity 0.4s ease, transform 0.4s ease;
    z-index: 2000; /* High z-index to stay above all other elements */
    box-shadow: 0px 15px 25px rgba(0, 0, 0, 0.2), 0px 10px 10px rgba(0, 0, 0, 0.1);
    overflow-y: auto;
}


/* Make modal visible when active */
.expanded-content.visible {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, -50%) scale(1);
}

/* Background title styling with a lower z-index */
#projects::before, .work-background-title {
    z-index: 1; /* Ensures background title stays below the modal */
}

/* Expanded Header with Company Logo */
.expanded-content .header {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 20px;
}

.expanded-content .header img {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
}

.expanded-content h3 {
    font-size: 1.4rem;
    margin: 0;
}

.expanded-content .date-range {
    font-size: 0.9rem;
    color: #777;
}

/* Project Information */
.project-info {
    font-size: 1rem;
    line-height: 1.6;
    color: #333;
    text-align: left;
}

/* Section Titles in Expanded Content */
.section-title {
    font-size: 1.1rem;
    font-weight: bold;
    color: #333;
    margin-top: 20px;
}

/* Close Button */
.close-button {
    padding: 10px 20px;
    background-color: #333;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    margin-top: 20px;
}

.close-button:hover {
    background-color: #555;
}

/* Responsive Adjustments */
@media (max-width: 768px) {
    .work-content {
        grid-template-columns: 1fr;
    }

    .expanded-content {
        width: 90vw;
        max-height: 80vh;
        overflow-y: auto;
    }
}


