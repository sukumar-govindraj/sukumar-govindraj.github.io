function openProject(card) {
    const modal = document.getElementById("projectModal");
    const modalThumbnail = modal.querySelector(".modal-thumbnail");
    const modalDescription = modal.querySelector(".modal-details p");
    const projectImages = modal.querySelectorAll(".project-images img");

    // Set the modal thumbnail and description dynamically based on the clicked card
    modalThumbnail.src = card.querySelector(".thumbnail").src;
    modalDescription.textContent = card.querySelector(".project-description").textContent;

    // Set project images (replace these with your actual images for each project)
    projectImages[0].src = "project-image1.jpg";
    projectImages[1].src = "project-image2.jpg";
    projectImages[2].src = "project-image3.jpg";

    // Show the modal
    modal.style.display = "flex";
}

function closeProject() {
    const modal = document.getElementById("projectModal");
    modal.style.display = "none";
}

// Close the modal when clicking outside the modal content
window.onclick = function(event) {
    const modal = document.getElementById("projectModal");
    if (event.target == modal) {
        modal.style.display = "none";
    }
};
